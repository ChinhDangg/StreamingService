{
  "settings": {
    "analysis": {
      "filter": {
        "autocomplete_ngram": {
          "type": "edge_ngram",
          "min_gram": 2,
          "max_gram": 20,
          "token_chars": ["letter", "digit", "punctuation", "symbol"]
        },
        "hyphen_handler": {
          "type": "word_delimiter_graph",
          "preserve_original": true,
          "catenate_words": true
        }
      },
      "analyzer": {
        "autocomplete": {
          "type": "custom",
          "tokenizer": "whitespace",
          "filter": [
            "lowercase",
            "hyphen_handler",
            "autocomplete_ngram"
          ]
        },
        "autocomplete_search": {
          "type": "custom",
          "tokenizer": "whitespace",
          "filter": [
            "lowercase",
            "hyphen_handler"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "userId": {
        "type": "long"
      },
      "name": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "autocomplete_search"
      },
      "thumbnail": {
        "type": "text"
      }
    }
  }
}
