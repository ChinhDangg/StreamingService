{
  "settings": {
    "analysis": {
      "filter": {
        "autocomplete_ngram": {
          "type": "edge_ngram",
          "min_gram": 2,
          "max_gram": 20,
          "token_chars": ["letter", "digit", "punctuation", "symbol"]
        },
        "hyphen_handler": {
          "type": "word_delimiter_graph",
          "preserve_original": true,
          "catenate_words": true
        }
      },
      "analyzer": {
        "autocomplete": {
          "type": "custom",
          "tokenizer": "whitespace",
          "filter": [
            "lowercase",
            "hyphen_handler",
            "autocomplete_ngram"
          ]
        },
        "autocomplete_search": {
          "type": "custom",
          "tokenizer": "whitespace",
          "filter": [
            "lowercase",
            "hyphen_handler"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "title": {
        "type": "text",
        "analyzer": "autocomplete",
        "search_analyzer": "autocomplete_search"
      },

      "tags": {
        "type": "nested",
        "properties": {
          "id": {
            "type": "long"
          },
          "name": {
            "type": "text",
            "analyzer": "autocomplete",
            "search_analyzer": "autocomplete_search"
          }
        }
      },
      "characters": {
        "type": "nested",
        "properties": {
          "id": {
            "type": "long"
          },
          "name": {
            "type": "text",
            "analyzer": "autocomplete",
            "search_analyzer": "autocomplete_search"
          }
        }
      },
      "universes": {
        "type": "nested",
        "properties": {
          "id": {
            "type": "long"
          },
          "name": {
            "type": "text",
            "analyzer": "autocomplete",
            "search_analyzer": "autocomplete_search"
          }
        }
      },
      "authors": {
        "type": "nested",
        "properties": {
          "id": {
            "type": "long"
          },
          "name": {
            "type": "text",
            "analyzer": "autocomplete",
            "search_analyzer": "autocomplete_search"
          }
        }
      },

      "uploadDate": {
        "type": "date",
        "format": "strict_date_optional_time_nanos"
      },
      "year": {
        "type": "integer"
      },
      "width": {
        "type": "integer"
      },
      "height": {
        "type": "integer"
      },
      "id": {
        "type": "long"
      },
      "userId": {
        "type": "long"
      },
      "bucket": {
        "type": "text"
      },
      "parentPath": {
        "type": "text"
      },
      "key": {
        "type": "text"
      },
      "thumbnail": {
        "type": "text"
      },
      "preview": {
        "type": "text"
      },
      "length": {
        "type": "integer"
      },
      "size": {
        "type": "long"
      },
      "groupInfo": {
        "properties": {
          "id": {
            "type": "long"
          },
          "grouperId": {
            "type": "long"
          },
          "numInfo": {
            "type": "text"
          }
        }
      }
    }
  }
}
